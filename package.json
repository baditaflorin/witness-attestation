{
  "name": "witness-attestation",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A client-side PWA for signing GPS/time observations into verifiable, portable presence attestations.",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "node scripts/build-pages.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "pages-preview": "vite preview --host 127.0.0.1 --outDir docs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "smoke": "bash scripts/smoke.sh",
    "install-hooks": "git config core.hooksPath .githooks",
    "hooks-pre-commit": "bash .githooks/pre-commit",
    "hooks-commit-msg": "bash .githooks/commit-msg .git/COMMIT_EDITMSG",
    "hooks-pre-push": "bash .githooks/pre-push",
    "clean": "rm -rf docs node_modules/.vite coverage playwright-report test-results"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.7",
    "idb": "^8.0.3",
    "libsodium-wrappers-sumo": "^0.8.4",
    "lucide-react": "^0.552.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.5"
  }
}
