#!/usr/bin/env bash
set -euo pipefail

message_file="${1:?commit message file required}"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data)(\([a-z0-9._-]+\))?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits." >&2
  echo "Examples: feat: add verifier, docs: record deployment mode" >&2
  exit 1
fi
