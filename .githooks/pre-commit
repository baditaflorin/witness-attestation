#!/usr/bin/env bash
set -euo pipefail

npm run fmt:check
npm run lint
npm run typecheck

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "gitleaks is required for pre-commit secret scanning." >&2
  echo "Install: https://github.com/gitleaks/gitleaks#installing" >&2
  exit 1
fi

gitleaks protect --staged --redact
